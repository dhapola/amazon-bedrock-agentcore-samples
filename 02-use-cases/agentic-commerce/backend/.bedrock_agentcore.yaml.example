default_agent: agentic_commerce
agents:
  agentic_commerce:
    name: agentic_commerce
    language: python
    node_version: '20'
    entrypoint: agent/src/main.py
    deployment_type: container
    runtime_type: null
    platform: linux/arm64
    container_runtime: finch
    source_path: agent
    aws:
      execution_role: null  # Will be auto-created or specify your role ARN
      execution_role_auto_create: true
      account: YOUR_AWS_ACCOUNT_ID  # Replace with your AWS account ID
      region: us-west-2  # Replace with your preferred region
      ecr_repository: null  # Will be auto-created
      ecr_auto_create: true
      s3_path: null
      s3_auto_create: false
      network_configuration:
        network_mode: PUBLIC
        network_mode_config: null
      protocol_configuration:
        server_protocol: HTTP
      observability:
        enabled: true
      lifecycle_configuration:
        idle_runtime_session_timeout: null
        max_lifetime: null
    bedrock_agentcore:
      agent_id: null  # Will be generated on deployment
      agent_arn: null  # Will be generated on deployment
      agent_session_id: null  # Will be generated on deployment
    codebuild:
      project_name: null
      execution_role: null
      source_bucket: null
    memory:
      mode: STM_AND_LTM
      memory_id: null
      memory_arn: null
      memory_name: agentic_commerce_memory
      event_expiry_days: 30
      first_invoke_memory_check_done: false
      was_created_by_toolkit: false
    identity:
      credential_providers: []
      workload: null
    aws_jwt:
      enabled: false
      audiences: []
      signing_algorithm: ES384
      issuer_url: null
      duration_seconds: 300
    authorizer_configuration:
      customJWTAuthorizer:
        discoveryUrl: null  # Will be set from frontend Cognito
        allowedClients: []  # Will be set from frontend Cognito
    request_header_configuration:
      requestHeaderAllowlist:
      - Authorization
    oauth_configuration: null
    api_key_env_var_name: null
    api_key_credential_provider_name: null
    is_generated_by_agentcore_create: false
